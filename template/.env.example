# Commerce database connection (same DB as portal)
COMMERCE_DATABASE_URL=postgresql://user:pass@localhost:5432/commerce

# Site configuration (set per-site)
CHANNEL_ID=1
SITE_URL=https://store.example.com

# Session secret for customer auth (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-secret

# Google OAuth (same client ID as portal)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Google Gemini API (for product embeddings / semantic search)
GOOGLE_API_KEY=your-google-api-key

# Stripe (for subscriptions and webhook verification)
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Meilisearch (product search)
MEILI_URL=http://localhost:7700
MEILI_API_KEY=dev-key
