# Lightweight image for running admin scripts from @keenan/services.
# Usage: docker build --build-arg SCRIPT=scripts/backfill-meilisearch.ts -f Dockerfile.admin .
#
# Requires keenan-services-admin.tar.gz in the build context root
# (created by CI via: cd _services && tar czf ../keenan-services-admin.tar.gz .)

FROM node:22-alpine

ARG SCRIPT=scripts/backfill-meilisearch.ts

WORKDIR /app

# Copy and extract the services repo
COPY keenan-services-admin.tar.gz ./
RUN tar xzf keenan-services-admin.tar.gz && rm keenan-services-admin.tar.gz

# Install dependencies (including devDependencies for tsx)
RUN npm install

# Build TypeScript
RUN npm run build

# Default: run the specified script
ENV SCRIPT=${SCRIPT}
CMD ["sh", "-c", "npx tsx $SCRIPT"]
